---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import Pagination from "@/components/Pagination.astro";

export async function getStaticPaths() {
  const postModules = import.meta.glob("../../../posts/*.astro", { eager: true });
  const allPosts = Object.values(postModules)
    .map((mod: any) => mod.post)
    .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

  const categories = [...new Set(allPosts.flatMap((p) => Array.isArray(p.category) ? p.category : [p.category]))];
const pageSize = 9;

  const paths = [];

  for (const category of categories) {
    const filteredPosts = allPosts.filter((p) => {
      const cats = Array.isArray(p.category) ? p.category : [p.category];
      return cats.includes(category);
    });
    const totalPages = Math.ceil(filteredPosts.length / pageSize);

    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { category, page: String(page) },
        props: { category, posts: allPosts, page, totalPages },
      });
    }
  }

  return paths;
}

export interface Props {
  category: string;
  posts: any[];
  page: number;
  totalPages: number;
}

const { category, posts: allPosts, page, totalPages } = Astro.props;
const pageSize = 6;
const filteredPosts = allPosts.filter((p) => {
  const cats = Array.isArray(p.category) ? p.category : [p.category];
  return cats.includes(category);
});
const pagePosts = filteredPosts.slice((page - 1) * pageSize, page * pageSize);

const basePath = `/category/${category}/page`;
---

<BaseLayout
  title={`${category} - الصفحة ${page}`}
  description={`مقالات ${category} على مصدر إكس - الصفحة ${page}`}
  keywords={[category, "تصنيفات", "مصادر مفتوحة"]}
  canonical={`/category/${category}/page/${page}/`}
  ogType="website"
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="mb-6 text-sm font-body text-gray-500">
      <a href="/" class="hover:text-charcoal transition-colors no-underline">الرئيسية</a>
      <span class="mx-2">/</span>
      <a href={`/category/${category}/`} class="hover:text-charcoal transition-colors no-underline text-gray-500">{category}</a>
      <span class="mx-2">/</span>
      <span class="text-charcoal">الصفحة {page}</span>
    </nav>

    <h1 class="font-heading text-3xl font-extrabold text-charcoal mb-2">
      تصنيف: {category}
    </h1>
    <p class="font-body text-gray-500 mb-8">{filteredPosts.length} مقال</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        pagePosts.map((post) => (
          <ArticleCard
            title={post.title}
            description={post.description}
            category={post.category}
            author={post.author}
            date={post.date}
            tags={post.tags}
            slug={post.slug}
            thumbnail={post.thumbnail}
          />
        ))
      }
    </div>

    <Pagination currentPage={page} totalPages={totalPages} basePath={basePath} />
  </section>
</BaseLayout>
