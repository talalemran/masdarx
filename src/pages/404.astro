---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="الصفحة غير موجودة"
  description="عذراً، الصفحة التي تبحث عنها غير موجودة."
  noIndex
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <h1 class="font-heading text-6xl font-extrabold text-charcoal mb-4">404</h1>
    <p class="font-body text-xl text-gray-600 mb-8">
      عذراً، الصفحة التي تبحث عنها غير موجودة.
    </p>
    <a
      href="/"
      class="inline-block px-8 py-3 bg-charcoal text-white font-heading font-bold text-base rounded-lg hover:bg-gray-800 transition-colors no-underline"
    >
      العودة إلى الرئيسية
    </a>
  </div>
</BaseLayout>
