            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-200 dark:divide-zinc-700">
            <tr>
              <td class="px-4 py-2">التكلفة</td>
              <td class="px-4 py-2">مجاني بالكامل</td>
              <td class="px-4 py-2">يتطلب ترخيصًا مدفوعًا</td>
            </tr>
            <tr>
              <td class="px-4 py-2">الأمان</td>
              <td class="px-4 py-2">أعلى بشكل عام، نادر التأثر بالفيروسات</td>
              <td class="px-4 py-2">مستهدف بشكل أكبر من البرمجيات الخبيثة</td>
            </tr>
            <tr>
              <td class="px-4 py-2">الأداء</td>
              <td class="px-4 py-2">خفيف وسريع حتى على أجهزة قديمة</td>
              <td class="px-4 py-2">قد يتطلب أجهزة أقوى</td>
            </tr>
            <tr>
              <td class="px-4 py-2">الخصوصية</td>
