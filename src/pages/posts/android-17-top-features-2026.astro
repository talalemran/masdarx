---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostLayout from "@/components/PostLayout.astro";

const postModules = import.meta.glob("../posts/*.astro", { eager: true });
const allPosts = Object.values(postModules)
  .map((mod: any) => mod.post)
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

export const post = {
  slug: "android-17-top-features-2026",
  title: "أبرز مزايا Android 17: فقاعات التطبيقات، الأمان، والألعاب",
  description:
    "Android 17 وصل رسميًا لأجهزة Pixel — إليك أبرز المزايا الجديدة من فقاعات التطبيقات العائمة وتسجيل الشاشة مع ردود الفعل، إلى وضع الألعاب على الأجهزة القابلة للطي وتحسينات الأمان.",
  keywords: [
    "Android 17",
    "أندرويد 17",
    "جوجل",
    "Google",
    "Pixel",
    "Gemini",
    "مزايا أندرويد",
    "تحديث أندرويد",
    "Bubbles",
    "فقاعات التطبيقات",
  ],
  category: "أندرويد",
  author: "فريق مصدر إكس",
  date: "5 يوليو 2026",
  pubDate: new Date("2026-07-05"),
  tags: ["Android", "Google", "Pixel", "Gemini", "أندرويد"],
  thumbnail: "/images/android-17-top-features-2026.webp",
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  keywords={post.keywords}
  canonical={`/posts/${post.slug}/`}
  ogImage={post.thumbnail}
  ogType="article"
>
  <PostLayout {post} allPosts={allPosts}>
    <p>
      <strong>Android 17</strong> وصل رسميًا في 16 يونيو 2026 لأجهزة Pixel، وسيتوسع
      تدريجيًا لبقية الأجهزة المؤهلة خلال 2026. الإصدار يركز على أربعة محاور: <strong
        >تعدد المهام، الترفيه، الأمان، والأداء</strong
      >. إليك أبرز ما جلبه.
    </p>

    <h2>فقاعات التطبيقات (Bubbles)</h2>

    <p>
      يمكنك الآن تحويل أي تطبيق إلى نافذة عائمة صغيرة فوق كل شيء آخر بمجرد الضغط
      المطوّل على أيقونته. على الأجهزة الكبيرة والقابلة للطي، تتجمع هذه الفقاعات
      في شريط مخصص بأسفل الشاشة للتنقل السريع بين التطبيقات وتغيير حجمها أو
      تكبيرها للشاشة الكاملة. مثالية لمراجعة الملاحظات أو الخرائط أثناء العمل.
    </p>

    <h2>تسجيل الشاشة مع ردود الفعل (Screen Reactions)</h2>

    <p>
      ميزة Screen Reactions تتيح تسجيل الشاشة مع الكاميرا الأمامية في آنٍ واحد،
      مع قطع الخلفية تلقائيًا دون الحاجة لشاشة خضراء. يمكنك تحريك نافذة الكاميرا
      وتغيير لون الخلفية أثناء التسجيل — مثالية لصنّاع المحتوى والشروحات
      التقنية.
    </p>

    <h2>وضع الألعاب على الأجهزة القابلة للطي</h2>

    <p>
      الأجهزة القابلة للطي تحصل على تخطيط 50/50 مُحسَّن — اللعبة في الأعلى ولوحة
      تحكم ديناميكية في الأسفل، مع إعادة تعيين أزرار وحدة التحكم الخارجية. كما
      خُففت انخفاضات الإطارات في الألعاب عالية الدقة بفضل تحسين إدارة الذاكرة.
    </p>

    <h2>تحسينات الخصوصية والأمان</h2>

    <ul>
      <li>
        <strong>وصول مؤقت للموقع:</strong> منح التطبيقات إذن الموقع الدقيق لجلسة واحدة
        فقط بدلًا من الوصول الدائم
      </li>
      <li>
        <strong>مشاركة جهات الاتصال:</strong> مشاركة جهات اتصال محددة فقط بدلًا من
        دفتر العناوين بالكامل
      </li>
      <li>
        <strong>قفل بيومتري عند السرقة:</strong> ميزة "Mark as lost" المحسّنة في Find
        Hub تقفل الجهاز ببصمة الإصبع حتى لو يعرف اللص الـ PIN
      </li>
      <li>
        <strong>الكشف الفوري عن التهديدات:</strong> Android 17 يفحص التطبيقات بحثًا
        عن سلوك مشبوه كتوجيه الرسائل أو إساءة استخدام خدمات إمكانية الوصول
      </li>
      <li>
        <strong>حماية من انتحال هوية البنوك:</strong> التحقق تلقائيًا في الخلفية إذا
        كانت المكالمة من بنك حقيقي أم لا
      </li>
    </ul>

    <h2>مزايا إضافية</h2>

    <ul>
      <li>
        <strong>Quick Share متوافق مع AirDrop:</strong> دعم موسّع يشمل أجهزة Samsung
        وOppo وOnePlus وXiaomi وHonor
      </li>
      <li>
        <strong>التنقل من iOS:</strong> نقل كامل للمحتوى من iPhone لأندرويد بما فيه
        الـ eSIM وتخطيط الشاشة الرئيسية
      </li>
      <li>
        <strong>تخصيص الشاشة الرئيسية:</strong> خيار إخفاء أسماء التطبيقات لمظهر أنظف
        وأكثر تنظيمًا
      </li>
      <li>
        <strong>Gemini Intelligence:</strong> ذكاء اصطناعي أعمق يتعامل مع مهام أكثر
        تعقيدًا طوال اليوم — يصل لأجهزة متقدمة مختارة لاحقًا في الصيف
      </li>
      <li>
        <strong>Jetpack Compose أولًا:</strong> كل واجهات برمجة Android الجديدة ستكون
        حصريًا لـ Compose، ومكونات View الكلاسيكية في وضع الصيانة فقط
      </li>
    </ul>

    <h2>الأجهزة المؤهلة</h2>

    <p>
      جميع أجهزة Pixel من Pixel 6 وحتى سلسلة Pixel 10 ستحصل على Android 17، مع
      تمديد دعم Pixel 6 وPixel 7 وPixel Fold بسنتين إضافيتين. الأجهزة الأخرى من
      المصنّعين المختلفين ستحصل عليه تدريجيًا قبل أكتوبر 2026.
    </p>

    <p>
      Android 17 ليس ثورة في التصميم بقدر ما هو ترسيخ لفلسفة جوجل: تعدد مهام
      أذكى، خصوصية أكثر دقة، وأدوات تجعل الهاتف أداةً إنتاجية حقيقية لا مجرد
      شاشة.
    </p>

    <h3>المصدر:</h3>
    <p>
      <a
        href="https://mashable.com/tech/top-android-17-features-to-get-excited-about"
        target="_blank"
        rel="noopener noreferrer"
      >
        Mashable
      </a>
    </p>
  </PostLayout>
</BaseLayout>
