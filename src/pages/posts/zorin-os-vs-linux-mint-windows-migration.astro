      alt="جدول مقارنة بين Zorin OS و Linux Mint"
      width="1200"
      height="800"
      class="w-full h-auto rounded-lg mb-4"
      loading="lazy"
    />

    <div class="overflow-x-auto my-4">
      <table
        class="w-full text-right border border-zinc-200 dark:border-zinc-700 rounded-lg"
      >
        <thead
          class="bg-zinc-100 dark:bg-zinc-800 light:text-zinc-700 dark:text-zinc-300"
        >
          <tr>
            <th class="px-4 py-2 font-semibold">المعيار</th>
            <th class="px-4 py-2 font-semibold">Linux Mint</th>
            <th class="px-4 py-2 font-semibold">Zorin OS</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-200 dark:divide-zinc-700">
          <tr>
            <td class="px-4 py-2">واجهة المستخدم</td>
            <td class="px-4 py-2">Cinnamon، عملية وكلاسيكية</td>
            <td class="px-4 py-2">GNOME معدّلة، أنيقة وحديثة، أقرب بصريًا لويندوز 11</td>
          </tr>
          <tr>
            <td class="px-4 py-2">استهلاك الموارد</td>
            <td class="px-4 py-2">خفيف، مثالي للأجهزة القديمة</td>
