---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostLayout from "@/components/PostLayout.astro";

const postModules = import.meta.glob("../posts/*.astro", { eager: true });
const allPosts = Object.values(postModules)
  .map((mod: any) => mod.post)
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

export const post = {
  slug: "kde-plasma-6-7-release",
  title: "إطلاق واجهة KDE Plasma 6.7",
  description: "إطلاق واجهة KDE Plasma 6.7: أهم الميزات والتحديثات الجديدة",
  keywords: ["KDE Plasma", "لينكس", "بيئة سطح المكتب", "كي دي اي بلازما"],
  category: "بيئة سطح المكتب",
  author: "فريق مصدر إكس",
  date: "18 يونيو 2026 ",
  pubDate: new Date("2026-06-18"),
  tags: ["KDE Plasma", "لينكس", "بيئة سطح المكتب"],
  thumbnail: "/images/kde-plasma.webp",
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  keywords={post.keywords}
  canonical={`/posts/${post.slug}/`}
  ogImage={post.thumbnail}
  ogType="article"
>
  <PostLayout {post} allPosts={allPosts}>
    <p>
      أعلن مجتمع KDE رسمياً عن إطلاق إصدار KDE Plasma 6.7، وهو التحديث الرئيسي
      السابع ضمن سلسلة Plasma 6. يأتي هذا الإصدار محملًا بالعديد من الميزات
      المنتظرة التي تركز على مرونة التخصيص، وتحسين الأداء، وسلاسة تجربة
      المستخدم.
    </p>
    <h2>إطلاق واجهة KDE Plasma 6.7: أهم الميزات والتحديثات الجديدة</h2>
    <figure class="my-8 flex justify-center">
      <img
        src="/images/kde-plasma-6-7.webp"
        alt="KDE Plasma 6.7"
        class="max-w-full h-auto rounded-lg"
      />
    </figure>
     <p>
      يعد KDE Plasma 6.7 تحديثًا مهمًا يركز على تحسين تجربة المستخدم من خلال
      تقديم ميزات جديدة ومبتكرة، بالإضافة إلى تحسينات كبيرة في الأداء والرسوميات.
      إليك أبرز ما جاء في هذا الإصدار:
    </p>
    <p>
      إليك أبرز ما جاء في هذا الإصدار:

      <ul>
        <li>
          أسطح مكتب افتراضية مستقلة لكل شاشة: تعد هذه الميزة الأبرز والأكثر
          طلباً من قِبل المستخدمين؛ حيث تتيح لك الآن التنقل بين مساحات العمل
          (Workspaces) بشكل مستقل تماماً على كل شاشة متصلة بجهازك، دون أن يتأثر
          ما يعرض على الشاشات الأخرى، مما يرفع كفاءة الإنتاجية وتعدد المهام.
        </li>
        <li>
          نظام التخصيص الثوري "Union": يقدم هذا الإصدار نسخة تجريبية (Preview)
          من نظام تخصيص المظهر الجديد الذي يُدعى "Union". يهدف هذا النظام إلى
          جعل عملية تعديل الثيمات وتوحيد مظهر التطبيقات وعناصر الواجهة أسهل
          بكثير، حيث يعتمد على لغة CSS الشهيرة لتمكين المطورين والمستخدمين من
          تخصيص الواجهة بمرونة فائقة.
        </li>
        <li>
          إحياء السمات الكلاسيكية (عودة سمة Air): لعشاق النوستالجيا، أعاد
          المطورون تصميم ودمج بعض المظاهر الكلاسيكية المحبوبة من عصر KDE 4،
          وتحديداً ثيم "Air" الشهير مع الخلفيات الأصلية المرتبطة به، ولكن
          بتحديثات تتناسب مع دقة الشاشات الحديثة.
        </li>
        <li>
          تحسينات كبيرة في الأداء والرسوميات: جاء هذا الإصدار بتحسينات قوية على
          مستوى النظام، أبرزها القدرة على تشغيل ملفات الألوان (ICC Profiles)
          وتقنية المدى الديناميكي العالي (HDR) معاً في نفس الوقت. بالإضافة إلى
          ذلك، تم تقليل استهلاك المعالج (CPU) وتحسين أداء العرض بشكل ملحوظ
          لأجهزة الكمبيوتر التي تعتمد على معالجات الرسوميات المدمجة من Intel
          (Intel iGPUs).
        </li>
        <li>
          ميزات وإضافات ذكية أخرى: * شريط النظام والتحكم بالصوت: أصبح بإمكان
          المستخدمين الآن اختبار صوت الميكروفون والتحقق من جودته مباشرة من شريط
          المهام (System Tray).
          <ul>
            <li>
              إدارة الطابعات: تم تسهيل عملية اكتشاف وإدارة طابعات الشبكة وإضافتها
              بنقرات أقل.
            </li>
            <li>
            متجر Discover: حصل متجر البرمجيات على تحسينات في سرعة التصفح وعرض
            التطبيقات وتحديثها.
          </li>
          </ul>
        </li>
      </ul>
    </p>

    <h3>لمسة وفاء:</h3>
    <p>
      جاء في الإعلان الرسمي لـ KDE أن هذا الإصدار (Plasma 6.7) تم إهداؤه تكريماً
      لذكرى "إيريك لافون" (Éric Lafoon)، وهو أحد أبرز المطورين والداعمين القدامى
      الذين ساهموا بشكل كبير في بناء وتطوير مجتمع KDE في بداياته.
    </p>
    <p>
      المصدر: <a href="https://itsfoss.com/news/kde-plasma-6-7-release/" target="_blank" rel="noopener noreferrer">KDE Plasma 6.7: What's New?</a>
    </p>
  </PostLayout>
</BaseLayout>
