---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostLayout from "@/components/PostLayout.astro";

const postModules = import.meta.glob("../posts/*.astro", { eager: true });
const allPosts = Object.values(postModules)
    .map((mod: any) => mod.post)
    .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

export const post = {
    slug: "ubuntu-26-04-update-notifications-disabled-gsettings",
    title: "أوبنتو 26.04 أصبح صامتًا: لماذا لا تظهر إشعارات التحديثات",
    description:
        "أوبنتو 26.04 LTS يعطّل أيقونة إشعارات التحديثات الافتراضية — بينما التحديثات الأمنية تُثبّت تلقائيًا في الخلفية، المستخدمون لم يعودوا يتلقون إشعارات. إليك كيفية تفعيلها مجددًا عبر gsettings.",
    keywords: [
        "Ubuntu 26.04",
        "أوبنتو",
        "update notifications",
        "تحديثات",
        "update-manager",
        "gsettings",
        "unattended-upgrades",
        "Software Updater",
        "Canonical",
        "إشعارات",
    ],
    category: "لينكس",
    author: "فريق مصدر إكس",
    date: "23 يوليو 2026",
    pubDate: new Date("2026-07-23"),
    tags: ["Ubuntu 26.04", "لينكس", "تحديثات", "أوبنتو", "Canonical"],
    thumbnail: "/images/ubuntu-26-04-update-notifications-disabled-gsettings.webp",
};
---

<BaseLayout
    title={post.title}
    description={post.description}
    keywords={post.keywords}
    canonical={`/posts/${post.slug}/`}
    ogImage={post.thumbnail}
    ogType="article"
>
    <PostLayout {post} allPosts={allPosts}>
        <p>
            إذا كان جهازك بـ <strong>أوبنتو 26.04 LTS</strong> لم يُنبّهك بشأن التحديثات
            المعلقة منذ فترة، فليس الأمر خلل — بل <strong
                >قرار تصميمي من Canonical</strong
            >. الإشعارات لم تختفِ لأنه لا توجد تحديثات، بل لأن <strong
                >أيقونة الإشعارات في شريط المهام معطّلة افتراضيًا</strong
            >.
        </p>

        <h2>ما الذي حدث؟</h2>

        <p>
            تقارير في Launchpad والحوارات على Ubuntu Discourse كشفت أن <strong
                >update-manager</strong
            > لم يعد يُظهر إشعارات بالتحديثات المعلقة <strong
                >إلا إذا كانت أيقونة الإشعارات مفعّلة</strong
            >. المشكلة؟ هذه الأيقونة <strong
                >معطّلة بشكل افتراضي في 26.04</strong
            >، وليس هناك خيار في الإعدادات لتفعيلها.
        </p>

        <h2>كيف يعمل النظام الجديد؟</h2>

        <p>
            أوبنتو يُشحن مع <strong>unattended-upgrades</strong> مفعّلًا افتراضيًا
            — وهذا يعني أن <strong
                >التحديثات الأمنية تُثبّت تلقائيًا في الخلفية دون إخبارك بها</strong
            >. هذا يُحسّن الأمان بدون إزعاج، لكنه يعني أيضًا أن الكثير من
            المستخدمين قد لا يعرفون حتى أن التحديثات تحدث.
        </p>

        <p>
            البديل الأقدم كان تطبيق Software Updater يظهر بشكل دوري عندما تكون
            هناك تحديثات، لكن كثيرين وجدوا هذا مزعجًا لأنه يأخذ التركيز من
            النافذة الحالية. حل في Ubuntu 25.10 أضاف <strong
                >إشعار سطح المكتب وأيقونة في الشريط الجانبي</strong
            > لتنبيهك بهدوء.
        </p>

        <h2>التغيير الآن</h2>

        <p>
            في Ubuntu 26.04، أيقونة الشريط الجانبي تم إيقافها افتراضيًا. <strong
                >Marco Trevisan</strong
            > من Canonical يؤكد أنها كانت "خيار تصميم"، لكن يمكن تفعيلها مجددًا عبر
            سطر الأوامر.
        </p>

        <h2>كيف تعيد تفعيل الإشعارات</h2>

        <p>
            إذا كنت تريد رؤية الإشعارات مجددًا، افتح الطرفية وشغّل الأمر التالي:
        </p>

        <pre><code>gsettings set com.ubuntu.update-notifier show-updates-status-icon true</code></pre>

        <p>
            لا توجد واجهة رسومية لهذا الإعداد في Settings، لذا يجب استخدام الأمر
            أعلاه أو أداة `dconf-editor` (لكن احذر من تغيير إعدادات أخرى
            بالخطأ).
        </p>

        <h2>خيارات التحديث الأخرى</h2>

        <ul>
            <li>
                <strong>Software Updater:</strong> يعمل كالمعتاد، لكن لن يظهر إشعار
                تلقائي إلا إذا فعّلت أيقونة الشريط
            </li>
            <li>
                <strong>سطر الأوامر:</strong> استخدم `apt upgrade` يدويًا في الطرفية
            </li>
            <li>
                <strong>App Center:</strong> منذ Ubuntu 26.04 يمكنه تحديث برامج Deb
                بجانب Snaps
            </li>
            <li>
                <strong>المثبّت والتحديثات (Software & Updates):</strong> تم حذف هذه
                الأداة من الإصدارات الجديدة لكن يمكنك تثبيتها من المستودعات إذا أردت
                تحكمًا أكثر تفصيلًا
            </li>
        </ul>

        <h2>هل هذا تغيير جيد؟</h2>

        <p>
            المنطق وراء هذا معقول — التحديثات الأمنية تثبّت تلقائيًا بدون إزعاج،
            والمستخدمون الذين يريدون رؤية الإشعارات يمكنهم تفعيلها يدويًا. لكن
            المستخدمين الطويلي المدى الذين اعتادوا على الإشعارات قد وجدوا هذا
            مربكًا في البداية.
        </p>

        <p>
            Ubuntu يفضل الهدوء والأمان الافتراضي على الإزعاج والتنبيهات المستمرة
            — وهذا منطقي، لكنه يتطلب من المستخدمين معرفة أن التغيير حدث.
        </p>

        <h3>المصدر:</h3>
        <p>
            <a
                href="https://www.omgubuntu.co.uk/2026/07/ubuntu-26-04-update-notifications-disabled"
                target="_blank"
                rel="noopener noreferrer"
            >
                OMG! Ubuntu
            </a>
        </p>
    </PostLayout>
</BaseLayout>
