---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostLayout from "@/components/PostLayout.astro";

const postModules = import.meta.glob("../posts/*.astro", { eager: true });
const allPosts = Object.values(postModules)
  .map((mod: any) => mod.post)
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

export const post = {
  slug: "android-17-app-bubbles-pixel-fold-multitasking",
  title: "Android 17 فقاعات التطبيقات على Pixel Fold: ثورة تعدد المهام",
  description:
    "فقاعات التطبيقات في Android 17 تحل مشكلة تعدد المهام على Pixel Fold — Google دمجتها في شريط المهام بدلًا من النوافذ العائمة، فأصبحت تجربة أقرب لسطح المكتب من الهاتف.",
  keywords: [
    "Android 17",
    "App Bubbles",
    "Pixel Fold",
    "Pixel 10 Pro Fold",
    "تعدد المهام",
    "Multitasking",
    "فقاعات التطبيقات",
    "Google",
    "أندرويد",
    "أجهزة قابلة للطي",
  ],
  category: "أخبار تقنية",
  author: "فريق مصدر إكس",
  date: "19 يوليو 2026",
  pubDate: new Date("2026-07-19"),
  tags: ["Android 17", "Pixel Fold", "Google", "multitasking", "أندرويد"],
  thumbnail: "/images/android-17-app-bubbles-pixel-fold-multitasking.webp",
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  keywords={post.keywords}
  canonical={`/posts/${post.slug}/`}
  ogImage={post.thumbnail}
  ogType="article"
>
  <PostLayout {post} allPosts={allPosts}>
    <p>
      منذ شهر تقريباً أطلقت جوجل <strong>Android 17</strong> بشكل رسمي لأجهزة Pixel،
      وكانت إحدى أبرز المزايا الجديدة هي <strong>App Bubbles</strong> — نوافذ عائمة
      تتيح تعدد مهام أسهل على الهواتف العادية. لكن على أجهزة مثل <strong
        >Pixel 10 Pro Fold</strong
      >، Google لم تقتصر على النوافذ العائمة — بل أدمجتها مباشرةً في شريط
      المهام، محولةً التجربة كاملةً.
    </p>

    <h2>كيف تعمل فقاعات التطبيقات على Pixel Fold؟</h2>

    <p>
      فقاعات التطبيقات تتيح فتح أي تطبيق في نافذة عائمة، وعند الانتهاء يمكنك
      تصغيرها إلى شريط المهام بدلًا من إغلاقها — يشعر الأمر تماماً كتصغير نافذة
      في نظام تشغيل سطح مكتب.
    </p>

    <p>
      على الهواتف العادية، التطبيقات المصغّرة تبقى فقاعات عائمة على حافة الشاشة.
      لكن على أجهزة قابلة للطي مثل Pixel Fold، Google دمجتها في شريط المهام، وهو
      ما يشعر بأنه تطبيق أنظف وأكثر تنظيمًا.
    </p>

    <h2>خطوات الاستخدام</h2>

    <ul>
      <li>اضغط مطولاً على أيقونة التطبيق في الشاشة الرئيسية أو في درج التطبيقات</li>
      <li>اختر <strong>"Bubble"</strong> من القائمة</li>
      <li>التطبيق يفتح فوراً كنافذة عائمة</li>
      <li>اضغط خارج النافذة لتصغيرها تلقائياً إلى شريط المهام</li>
      <li>اسحبها لأسفل الشاشة لإغلاقها نهائياً</li>
    </ul>

    <h2>التطبيق يستمر في العمل</h2>

    <p>
      التطبيق يستمر في التشغيل في الخلفية بعد تصغيره، وعندما تريد الرجوع، اضغط على
      أيقونته في شريط المهام. هذا يعني أنك إذا كانت YouTube تشغّل فيديو وصغّرتها،
      ستستمر الموسيقى أو الفيديو في التشغيل بينما تعمل على شيء آخر.
    </p>

    <h2>محدودية بسيطة</h2>

    <ul>
      <li>
        <strong>5 فقاعات كحد أقصى:</strong> لا يمكنك فتح أكثر من 5 تطبيقات فقاعات في نفس
        الوقت
      </li>
      <li>
        <strong>خطوة إضافية على الأجهزة القابلة للطي:</strong> إذا كان التطبيق يشغل الشاشة
        كاملة، تحتاج للسحب لأعلى قليلاً لإظهار شريط المهام قبل الضغط على الفقاعة
      </li>
      <li>
        <strong>لا تحويل تطبيق مفتوح:</strong> لا يمكنك تحويل تطبيق يعمل بالفعل إلى فقاعة
        — عليك إعادة فتحه من الأيقونة
      </li>
    </ul>

    <h2>حالة الاستخدام الواقعية</h2>

    <p>
      العمل على Pixel Fold يصبح أسهل كثيراً. عند كتابة مقالة مثلاً، يمكنك فتح Chrome
      كفقاعة، البحث عن معلومة، تصغيرها، والعودة للكتابة — كل دون فوضى من النوافذ
      المتعددة. نفس الأمر مع YouTube — بدلاً من نافذة صغيرة عائمة مزعجة، استخدم الفقاعة
      للتنقل السريع دون مقاطعة المهمة الأساسية.
    </p>

    <p>
      Google أخيراً حلّت مشكلة حقيقية في تعدد المهام على الأجهزة القابلة للطي —
      والحل بسيط وأنيق وفعّال. هذا ما يجب أن يبدو عليه التطبيق متعدد المهام في 2026.
    </p>

    <h3>المصدر:</h3>
    <p>
      <a
        href="https://www.androidpolice.com/android-17-app-bubbles-pixel-fold/"
        target="_blank"
        rel="noopener noreferrer"
      >
        Android Police
      </a>
    </p>
  </PostLayout>
</BaseLayout>
