---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostLayout from "@/components/PostLayout.astro";

const postModules = import.meta.glob("../posts/*.astro", { eager: true });
const allPosts = Object.values(postModules)
  .map((mod: any) => mod.post)
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

export const post = {
  slug: "thunderbird-153-oauth-thundermail-integration-63-fixes",
  title: "ثاندربيرد 153: دعم Thundermail الأصلي وحماية OAuth محسّنة و63 إصلاح",
  description:
    "Thunderbird 153 يصدر رسميًا 21 يوليو — دمج Thundermail مباشرة بدون إضافة، فتح OAuth في المتصفح الافتراضي، مؤشرات لون الحسابات، وإصلاحات واسعة لـ EWS وOpenPGP وأداء فك التشفير.",
  keywords: [
    "Thunderbird 153",
    "ثاندربيرد",
    "Thundermail",
    "OAuth",
    "عميل بريد إلكتروني",
    "Mozilla",
    "مفتوح المصدر",
    "تحديث أمني",
    "OpenPGP",
    "S/MIME",
  ],
  category: "برامج",
  author: "فريق مصدر إكس",
  date: "22 يوليو 2026",
  pubDate: new Date("2026-07-22"),
  tags: ["Thunderbird", "Mozilla", "بريد إلكتروني", "OAuth", "مفتوح المصدر"],
  thumbnail: "/images/thunderbird-153-oauth-thundermail-integration-63-fixes.webp",
};
---

<BaseLayout
  title={post.title}
  description={post.description}
  keywords={post.keywords}
  canonical={`/posts/${post.slug}/`}
  ogImage={post.thumbnail}
  ogType="article"
>
  <PostLayout {post} allPosts={allPosts}>

    <p>أطلقت <strong>Mozilla</strong> رسميًا <strong>Thunderbird 153</strong> في 21 يوليو 2026 — الإصدار الأحدث من عميل البريد الإلكتروني مفتوح المصدر يحمل تحسينات كبرى في المصادقة وتجربة المستخدم، إلى جانب <strong>63 إصلاح</strong> وتحسينات استقرار واسعة.</p>

    <h2>أبرز المزايا الجديدة</h2>

    <h3>دمج Thundermail الأصلي</h3>

    <p>Thunderbird 153 الآن يدعم استخدام خدمات Thundermail بشكل أصلي دون الحاجة لتثبيت إضافة منفصلة.  هذا يبسّط العملية بشكل كبير لأي شخص يريد الاشتراك في خدمة البريل الإلكتروني من Mozilla.</p>

    <h3>تحسين OAuth والمتصفح الافتراضي</h3>

    <p>مصادقة OAuth لحسابات البريد الآن تفتح في متصفحك الافتراضي بدلًا من داخل Thunderbird،  مما يوفر تجربة أكثر أماناً وراحة. كما يدعم الإصدار الجديد التحقق من حقول المُصدِّر في استجابات OAuth ورفض المُصدرات الناقصة والمطلوبة.</p></p> 

    <h3>مؤشرات لون الحسابات</h3>

    <p>المجلدات الموحدة الآن تعرض مؤشر لون حسابك مع تلميح يظهر اسم الحساب المقابل،  مما يسهّل التعرف على الحسابات المختلفة في لمحة سريعة.</p>

    <h2>إصلاحات جوهرية</h2>

    <ul>
      <li><strong>ملفات PDF:</strong> مشكلة Ctrl+S لم تحفظ ملفات PDF المفتوحة في تبويبات Thunderbird — تم إصلاحها الآن</li> 
      <li><strong>تنبيهات متعددة الشاشات:</strong> مشكلة تحجيم أو موضع نوافذ التنبيهات غير الصحيح على إعدادات الشاشات المتعددة</li> 
      <li><strong>أخطاء TLS:</strong> أخطاء TLS كانت تُبلِّغ بشكل غير صحيح عن جميع الأخطاء المجهولة كشهادات غير موثوقة</li> 
      <li><strong>المجلدات الافتراضية:</strong> إصلاح اثنتين من مشاكل المجلدات الافتراضية المهمة</li>
      <li><strong>أداء فك التشفير:</strong> تم إصلاح مشكلة أداء تم اكتشافها عند فك تشفير الرسائل المشفرة</p></li> 
      <li><strong>تغيير حجم الشريط الجانبي:</strong> الآن يمكن تغيير حجم جزء المجلد أفقياً في تبويبات إضافية من 3 أجزاء</li>
      <li><strong>فرز المجلدات:</strong> تصحيح فرز المجلدات الرقمية التي كانت تُفرز أبجديًا بدلًا من طبيعيًا</li>
    </ul>

    <h2>تحسينات OpenPGP و S/MIME</h2>

    <ul>
      <li>إصلاح فشل الرسائل من Apple Mail في فك التشفير بسبب مفتاح المستقبِل المخفي</li>
      <li>تحسين الأداء عند فتح الرسائل التي تحتوي على مفاتيح OpenPGP ذات حلقات مفاتيح كبيرة</li>
      <li>تحديث منطق التحقق من التوقيعات الرقمية</li>
      <li>إصلاح العديد من المشاكل المتعلقة بـ Key Refresh</li>
    </ul>

    <h2>إزالة الدعم القديم</h2>

    <p>Thunderbird 153 أزال دعم Odnoklassniki chat القديم وشجّع المستخدمين على الانتقال إلى XMPP بدلًا منه،  كجزء من جهد أوسع لتنظيف قاعدة الأكواد والتركيز على معايير المراسلة الحديثة.</p>

    <h2>توقيت الإصدار</h2>

    <p>Thunderbird 153 يرافق <strong>Firefox 140 ESR</strong> الذي سيتلقى تحديثات حتى سبتمبر 2026. بمجرد انتهاء دعم Firefox 140 ESR، سيتولى <strong>Firefox 153 ESR</strong> مكانه إلى جانب سلسلة Firefox 115 ESR الأقدم.</p>

    <p>Thunderbird 153 تحديث متوازن — ليس ثورة واجهة المستخدم، بل تحسينات عملية مركزة على الأمان والأداء والاستقرار، وهو بالضبط ما يحتاجه عميل بريد إلكتروني موثوق.</p>

    <h3>المصدر:</h3>
    <p>
      <a href="https://9to5linux.com/mozilla-thunderbird-153-is-out-with-various-new-features-and-many-fixes" target="_blank" rel="noopener noreferrer">
        9to5Linux
      </a>
    </p>

  </PostLayout>
</BaseLayout>