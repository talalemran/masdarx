  { name: "ذكاء اصطناعي", icon: "M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 1.98-.88 4.55-2.64 6.29-3.51 3.48-9.21 3.48-12.72 0-3.5-3.47-3.53-9.11-.02-12.58s9.14-3.49 12.65 0L21 3v7.12zM12.5 8v4.25l3.5 2.08-.72 1.21L11 13V8h1.5z", href: "/category/ذكاء اصطناعي/" },
  { name: "برامج", icon: "M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z", href: "/category/برامج/" },
  { name: "بيئة سطح المكتب", icon: "M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7l-2 3v1h8v-1l-2-3h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 12H3V4h18v10z", href: "/category/بيئة سطح المكتب/" },
  { name: "مقالات", icon: "M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z", href: "/category/مقالات/" },
];
---

<BaseLayout
  title="منصة أخبار المشاريع المفتوحة المصدر"
  description="مصدر إكس هي منصتك العربية الأولى لأخبار المشاريع مفتوحة المصدر والتقنيات الحديثة. تابع أحدث الأخبار، التحليلات، والمراجعات في عالم المصادر المفتوحة."
  keywords={[
    "مصدر إكس",
    "أخبار المصادر المفتوحة",
    "تقنيات حديثة",
    "برمجيات مفتوحة المصدر",
    "تكنولوجيا المعلومات",
    "تطوير البرمجيات",
    "لينكس",
    "برمجة",
    "المشاريع المفتوحة المصدر",
  ]}
  canonical="/"
  ogType="website"
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NewsMediaOrganization",
      name: "مصدر إكس",
      url: "https://www.masdarx.com",
      logo: "https://www.masdarx.com/favicon.svg",
      description:
        "منصة عربية متخصصة في أخبار البرمجيات مفتوحة المصدر والتقنيات الحديثة",
      inLanguage: "ar",
      areaServed: {
        "@type": "Country",
        name: "العالم العربي",
      },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: "https://www.masdarx.com/search?q={search_term_string}",
        },
        "query-input": "required name=search_term_string",
      },
    })}
  />

  <section class="bg-black text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <span
          class="inline-block px-4 py-1.5 text-xs font-bold font-heading tracking-wider uppercase bg-white/10 text-white/80 rounded-full mb-6 border border-white/20"
        >
          مصدر إكس
        </span>
        <h1
          class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-loose" style="line-height: 1.5;"
        >
          أخبار المشاريع المفتوحة المصدر بالعربية
        </h1>
        <p
          class="font-body text-lg sm:text-xl text-gray-300 max-w-xl mx-auto mb-8 leading-relaxed"
        >
          تابع آخر أخبار المشاريع مفتوحة المصدر، التوزيعات، والأدوات التقنية —
          كل ما تحتاجه في مكان واحد.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/about/"
            class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-white text-charcoal rounded-full hover:bg-gray-100 transition-colors no-underline"
          >
            تعرّف علينا
          </a>
          <a
            href="#recent-articles"
            class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-white/10 text-white rounded-full border border-white/20 hover:bg-white/20 transition-colors no-underline"
          >
            تصفّح المقالات
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="flex items-center justify-center gap-3 px-6 py-5 bg-white rounded-xl border border-gray-200 hover:border-charcoal hover:shadow-md transition-all no-underline group text-center"
          >
            <svg class="w-7 h-7 text-charcoal" fill="currentColor" viewBox={cat.viewBox || "0 0 24 24"}>
              <path d={cat.icon} />
              {cat.icon2 && <path fill-rule="evenodd" d={cat.icon2} />}
            </svg>
            <span class="font-body text-lg font-semibold text-charcoal">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {featured ? (
      <section class="bg-white pb-10 sm:pb-14 pt-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          
          <div class="flex items-center gap-3 mb-8" id="recent-articles">
            <h2 class="font-heading text-2xl font-bold text-charcoal">أحدث المقالات</h2>
            <a
              href="/page/2/"
              class="mr-auto font-body text-sm text-gray-500 hover:text-charcoal transition-colors no-underline"
            >
              عرض الكل &larr;
            </a>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <a
              href={`/posts/${featured.slug}/`}
              class="block no-underline group"
            >
            {featured.thumbnail && (
              <div class="bg-gray-100 rounded-xl overflow-hidden">
                <img
                  src={featured.thumbnail}
                  alt={featured.title}
                  width="720"
                  height="405"
                  class="w-full h-auto"
                />
              </div>
            )}
            </a>
            <div>
              <div class="flex flex-wrap gap-2 mb-4">
                {(Array.isArray(featured.category) ? featured.category : [featured.category]).map((cat: string) => (
                  <a
                    href={`/category/${cat}/`}
                    class="inline-block px-3 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full hover:bg-gray-800 transition-colors no-underline"
                  >
                    {cat}
                  </a>
                ))}
              </div>
              <a
                href={`/posts/${featured.slug}/`}
                class="block no-underline group"
              >
                <h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-extrabold text-charcoal mb-4 leading-tight group-hover:text-gray-700 transition-colors">
                  {featured.title}
                </h2>
              </a>
              <p class="font-body text-base text-gray-600 mb-4 leading-relaxed line-clamp-3">
                {featured.description}
              </p>
              <div class="flex items-center gap-2 text-sm text-gray-500 font-body mb-4">
                <span>{featured.author}</span>
                <span>•</span>
                <span>{featured.date}</span>
              </div>
              {featured.tags && featured.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {featured.tags.map((tag: string) => (
                    <a
                      href={`/tags/${tag}/`}
                      class="inline-block px-3 py-1 text-xs font-body text-gray-600 bg-gray-100 rounded-full hover:bg-gray-200 transition-colors no-underline"
                    >
                      {tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      </section>
    ) : null}

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        pagePosts.map((post) => (
          <ArticleCard
            title={post.title}
            description={post.description}
            category={post.category}
            author={post.author}
            date={post.date}
            tags={post.tags}
            slug={post.slug}
            thumbnail={post.thumbnail}
          />
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <Pagination currentPage={currentPage} totalPages={totalPages} />
      )
    }
  </section>

  <section class="bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="font-heading text-2xl font-bold text-charcoal">آخر المشاريع مفتوحة المصدر</h2>
        <a href="/projects/" class="mr-auto font-body text-sm text-gray-500 hover:text-charcoal transition-colors no-underline">عرض الكل &larr;</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestProjects.map((project) => (
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
            <a href={`/projects/${project.slug}/`} class="block no-underline">
              {project.thumbnail && (
                <div class="bg-gray-100 overflow-hidden">
                  <img
                    src={project.thumbnail}
                    alt={project.name}
                    width="400"
                    height="225"
                    class="w-full h-auto"
                    loading="lazy"
                  />
                </div>
              )}
            </a>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <a
                  href={`/projects/category/${Array.isArray(project.category) ? project.category[0] : project.category}/`}
                  class="px-2 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full hover:bg-gray-700 transition-colors no-underline"
                >
                  {Array.isArray(project.category) ? project.category[0] : project.category}
                </a>
                <span class="text-xs font-body text-gray-500">{project.language}</span>
              </div>
              <a href={`/projects/${project.slug}/`} class="block no-underline">
                <h3 class="font-heading text-lg font-bold text-charcoal mb-2 hover:text-gray-700 transition-colors">
                  {project.name}
                </h3>
              </a>
              <p class="font-body text-sm text-gray-600 leading-relaxed line-clamp-2">
                {project.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
