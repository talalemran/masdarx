---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import Pagination from "@/components/Pagination.astro";

const postModules = import.meta.glob("./posts/*.astro", { eager: true });
const posts = Object.values(postModules)
  .map((mod: any) => mod.post)
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const pageSize = 6;
const totalPages = Math.ceil(posts.length / pageSize);
const currentPage = 1;
const pagePosts = posts.slice(0, pageSize);
---

<BaseLayout
  title="منصة أخبار المصادر المفتوحة"
  description="مصدر إكس هي منصتك العربية الأولى لأخبار البرمجيات مفتوحة المصدر والتقنيات الحديثة. تابع أحدث الأخبار، التحليلات، والمراجعات في عالم المصادر المفتوحة."
  keywords={[
    "مصدر إكس",
    "أخبار المصادر المفتوحة",
    "تقنيات حديثة",
    "برمجيات مفتوحة المصدر",
    "تكنولوجيا المعلومات",
    "تطوير البرمجيات",
    "لينكس",
    "برمجة",
  ]}
  canonical="/"
  ogType="website"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsMediaOrganization",
    "name": "مصدر إكس",
    "url": "https://www.masdarx.com",
    "logo": "https://www.masdarx.com/favicon.svg",
    "description": "منصة عربية متخصصة في أخبار البرمجيات مفتوحة المصدر والتقنيات الحديثة",
    "inLanguage": "ar",
    "areaServed": {
      "@type": "Country",
      "name": "العالم العربي"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.masdarx.com/search?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />

  <section class="bg-black text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block px-4 py-1.5 text-xs font-bold font-heading tracking-wider uppercase bg-white/10 text-white/80 rounded-full mb-6 border border-white/20">
          مصدر إكس
        </span>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
          أخبار المصادر المفتوحة<br class="hidden sm:block" /> بالعربية
        </h1>
        <p class="font-body text-lg sm:text-xl text-gray-300 max-w-xl mx-auto mb-8 leading-relaxed">
          تابع آخر أخبار البرمجيات مفتوحة المصدر، التوزيعات، والأدوات التقنية — كل ما تحتاجه في مكان واحد.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/about/" class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-white text-charcoal rounded-full hover:bg-gray-100 transition-colors no-underline">
            تعرّف علينا
          </a>
          <a href="#recent-articles" class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-white/10 text-white rounded-full border border-white/20 hover:bg-white/20 transition-colors no-underline">
            تصفّح المقالات
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h2 class="font-heading text-2xl font-bold text-charcoal mb-8" id="recent-articles">
      أحدث المقالات
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        pagePosts.map((post) => (
          <ArticleCard
            title={post.title}
            description={post.description}
            category={post.category}
            author={post.author}
            date={post.date}
            tags={post.tags}
            slug={post.slug}
            thumbnail={post.thumbnail}
          />
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <Pagination currentPage={currentPage} totalPages={totalPages} />
      )
    }
  </section>
</BaseLayout>
