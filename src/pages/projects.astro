---
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = [
  {
    name: "Zen Browser",
    description: "متصفح مفتوح المصدر مبني على فايرفوكس، يركّز على الخصوصية والخصوصية مع واجهة عصرية وقابلة للتخصيص.",
    url: "https://github.com/zen-browser/desktop",
    website: "https://zen-browser.app",
    category: "متصفحات",
    language: "TypeScript",
    stars: "25k+",
    license: "MPL-2.0",
    tags: ["متصفح", "خصوصية", "فايرفوكس", "مفتوح المصدر"],
  },
  {
    name: "Linux Mint",
    description: "توزيعة لينكس سهلة الاستخدام مبنية على Ubuntu، مصممة لتقديم تجربة سطح مكتب أنيقة ومستقرة للمبتدئين والمتقدمين.",
    url: "https://github.com/linuxmint",
    website: "https://linuxmint.com",
    category: "توزيعات لينكس",
    language: "Various",
    stars: "7k+",
    license: "GPL-2.0",
    tags: ["توزيعة", "لينكس", "سطح مكتب", "مبتدئين"],
  },
  {
    name: "GIMP",
    description: "برنامج تعديل الصور المفتوح المصدر — بديل قوي لـ Photoshop مع دعم شامل للأدوات الاحترافية.",
    url: "https://gitlab.gnome.org/GNOME/gimp",
    website: "https://www.gimp.org",
    category: "برامج",
    language: "C",
    stars: "4k+",
    license: "GPL-3.0",
    tags: ["تعديل صور", "تصميم", "مفتوح المصدر", "بديل Photoshop"],
  },
  {
    name: "OBS Studio",
    description: "برنامج مفتوح المصدر للبث المباشر وتسجيل الشاشة — الأداة الأشهر للمبدعين والم-streamers.",
    url: "https://github.com/obsproject/obs-studio",
    website: "https://obsproject.com",
    category: "برامج",
    language: "C/C++",
    stars: "60k+",
    license: "GPL-2.0",
    tags: ["بث مباشر", "تسجيل شاشة", "فيديو", "مبدعون"],
  },
  {
    name: "Blender",
    description: "أداة نمذجة وتصميم ثلاثية الأبعاد مفتوحة المصدر — تُستخدم في الأفلام والألعاب والإعلانات.",
    url: "https://projects.blender.org/blender/blender",
    website: "https://www.blender.org",
    category: "تصميم",
    language: "C/C++",
    stars: "15k+",
    license: "GPL-2.0",
    tags: ["ثلاثية الأبعاد", "تصميم", "أنيميشن", "ألعاب"],
  },
  {
    name: "Nextcloud",
    description: "منصة مفتوحة المصدر للمستودعات السحابية — بديل خاص لـ Google Drive وDropbox مع تطبيقات متعددة.",
    url: "https://github.com/nextcloud/server",
    website: "https://nextcloud.com",
    category: "سحابة",
    language: "PHP",
    stars: "25k+",
    license: "AGPL-3.0",
    tags: ["سحابة", "خصوصية", "مشاركة ملفات", "تعاون"],
  },
];
---

<BaseLayout
  title="مشاريع مفتوحة المصدر"
  description="دليلك لأفضل المشاريع مفتوحة المصدر العربية والعالمية — متصفحات، أدوات، تطبيقات، والمزيد."
  keywords={["مشاريع مفتوحة المصدر", "open source", "برمجيات مجانية", "مفتوح المصدر"]}
  canonical="/projects/"
  ogType="website"
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h1 class="font-heading text-3xl sm:text-4xl font-extrabold text-charcoal mb-4">
        مشاريع مفتوحة المصدر
      </h1>
      <p class="font-body text-lg text-gray-600 leading-relaxed">
        دليلك لأفضل المشاريع مفتوحة المصدر — اكتشف، استخدم، وساهم.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-charcoal rounded-lg flex items-center justify-center">
              <span class="text-white font-heading font-bold text-sm">{project.name.charAt(0)}</span>
            </div>
            <div>
              <h2 class="font-heading text-lg font-bold text-charcoal">
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:text-gray-700 transition-colors no-underline text-charcoal">
                  {project.name}
                </a>
              </h2>
              <span class="text-xs font-body text-gray-500">{project.language}</span>
            </div>
          </div>

          <p class="font-body text-sm text-gray-600 leading-relaxed mb-4">
            {project.description}
          </p>

          <div class="flex items-center gap-4 text-xs font-body text-gray-500 mb-4">
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
              {project.stars}
            </span>
            <span>{project.license}</span>
          </div>

          <div class="flex flex-wrap gap-1.5 mb-4">
            {project.tags.map((tag) => (
              <span class="px-2 py-1 text-xs font-body text-gray-600 bg-gray-100 rounded-full">
                {tag}
              </span>
            ))}
          </div>

          <div class="flex gap-2">
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 text-center px-4 py-2 text-sm font-body font-medium bg-charcoal text-white rounded-lg hover:bg-gray-800 transition-colors no-underline"
            >
              GitHub
            </a>
            <a
              href={project.website}
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 text-center px-4 py-2 text-sm font-body font-medium bg-gray-100 text-charcoal rounded-lg hover:bg-gray-200 transition-colors no-underline"
            >
              الموقع
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="font-body text-sm text-gray-500">
        هل تعرف مشروعًا مفتوح المصدر يجب أن نضيفه؟
        <a href="/contact/" class="text-charcoal hover:text-gray-700 transition-colors no-underline font-medium">أرسله لنا</a>
      </p>
    </div>
  </section>
</BaseLayout>
