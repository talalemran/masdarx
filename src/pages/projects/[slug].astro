---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/projects";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

export interface Props {
  project: typeof projects[0];
}

const { project } = Astro.props;
const { name, description, url, website, category, language, stars, license, tags, thumbnail, features, useCases } = project;
const categories = Array.isArray(category) ? category : [category];

const relatedProjects = projects
  .filter((p) => p.slug !== project.slug)
  .filter((p) => {
    const pCats = Array.isArray(p.category) ? p.category : [p.category];
    return pCats.some((c) => categories.includes(c)) || p.tags.some((t) => tags.includes(t));
  })
  .slice(0, 3);

const projectUrl = `https://www.masdarx.com/projects/${project.slug}/`;
---

<BaseLayout
  title={name}
  description={description}
  keywords={tags}
  canonical={`/projects/${project.slug}/`}
  ogImage={thumbnail}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": name,
    "description": description,
    "url": url,
    "codeRepository": url,
    "programmingLanguage": language,
    "license": `https://spdx.org/licenses/${license}`,
    "applicationCategory": categories.join(", "),
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  })} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="mb-6 text-sm font-body text-gray-500">
      <a href="/" class="hover:text-charcoal transition-colors no-underline">الرئيسية</a>
      <span class="mx-2">/</span>
      <a href="/projects/" class="hover:text-charcoal transition-colors no-underline text-gray-500">المشاريع</a>
      <span class="mx-2">/</span>
      {categories.map((cat, i) => (
        <>
          <a
            href={`/projects/category/${cat}/`}
            class="hover:text-charcoal transition-colors no-underline text-gray-500"
          >
            {cat}
          </a>
          {i < categories.length - 1 && <span class="mx-2">,</span>}
        </>
      ))}
    </nav>

    {
      thumbnail && (
        <div class="bg-gray-100 rounded-xl overflow-hidden mb-8">
          <img src={thumbnail} alt={name} width="720" height="405" class="w-full h-auto" />
        </div>
      )
    }

    <div class="flex flex-wrap items-center gap-3 text-sm font-body text-gray-500 mb-4">
      {categories.map((cat) => (
        <a
          href={`/projects/category/${cat}/`}
          class="inline-block px-3 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full hover:bg-gray-700 transition-colors no-underline"
        >
          {cat}
        </a>
      ))}
      <span>{language}</span>
      <span>•</span>
      <span>{license}</span>
    </div>

    <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-extrabold text-charcoal mb-6 leading-snug">
      {name}
    </h1>

    <p class="font-body text-lg text-gray-600 leading-relaxed mb-8">
      {description}
    </p>

    <div class="flex gap-3 mb-8">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-charcoal text-white rounded-lg hover:bg-gray-800 transition-colors no-underline"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        GitHub
      </a>
      <a
        href={website}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-gray-100 text-charcoal rounded-lg hover:bg-gray-200 transition-colors no-underline"
      >
        الموقع الرسمي
      </a>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-8">
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">التصنيف</span>
        <span class="font-heading text-sm font-bold text-charcoal">{categories.join(", ")}</span>
      </div>
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">اللغة</span>
        <span class="font-heading text-sm font-bold text-charcoal">{language}</span>
      </div>
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">النجوم</span>
        <span class="font-heading text-sm font-bold text-charcoal">{stars}</span>
      </div>
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">الرخصة</span>
        <span class="font-heading text-sm font-bold text-charcoal">{license}</span>
      </div>
    </div>

    {features && features.length > 0 && (
      <div class="mb-8">
        <h2 class="font-heading text-xl font-bold text-charcoal mb-4">المميزات</h2>
        <ul class="space-y-2">
          {features.map((feature) => (
            <li class="flex items-center gap-2 font-body text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    )}

    {useCases && useCases.length > 0 && (
      <div class="mb-8">
        <h2 class="font-heading text-xl font-bold text-charcoal mb-4">حالات الاستخدام</h2>
        <div class="flex flex-wrap gap-2">
          {useCases.map((useCase) => (
            <span class="px-3 py-1.5 text-sm font-body text-gray-600 bg-gray-100 rounded-full">
              {useCase}
            </span>
          ))}
        </div>
      </div>
    )}

    {tags && tags.length > 0 && (
      <div class="mb-8">
        <h2 class="font-heading text-xl font-bold text-charcoal mb-4">الوسوم</h2>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="px-3 py-1.5 text-sm font-body text-gray-600 bg-gray-100 rounded-full hover:bg-gray-200 transition-colors no-underline"
            >
              {tag}
            </a>
          ))}
        </div>
      </div>
    )}

    {relatedProjects.length > 0 && (
      <div class="mt-10 pt-6 border-t border-gray-100">
        <h2 class="font-heading text-lg font-bold text-charcoal mb-4">مشاريع مشابهة</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedProjects.map((rp) => (
            <a
              href={`/projects/${rp.slug}/`}
              class="block p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors no-underline"
            >
              <h3 class="font-heading text-sm font-bold text-charcoal mb-1">{rp.name}</h3>
              <p class="font-body text-xs text-gray-500 line-clamp-2">{rp.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-8">
      <a
        href="/projects/"
        class="inline-flex items-center gap-2 font-body text-sm font-medium text-charcoal hover:text-gray-600 transition-colors no-underline"
      >
        &larr; العودة إلى المشاريع
      </a>
    </div>
  </article>
</BaseLayout>
