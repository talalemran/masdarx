---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects } from "@/data/projects";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

export interface Props {
  project: typeof projects[0];
}

const { project } = Astro.props;
const { name, description, url, website, category, language, stars, license, tags, thumbnail, features, useCases } = project;
const categories = Array.isArray(category) ? category : [category];

const relatedProjects = projects
  .filter((p) => p.slug !== project.slug)
  .filter((p) => {
    const pCats = Array.isArray(p.category) ? p.category : [p.category];
    return pCats.some((c) => categories.includes(c)) || p.tags.some((t) => tags.includes(t));
  })
  .slice(0, 3);

const projectUrl = `https://www.masdarx.com/projects/${project.slug}/`;
---

<BaseLayout
  title={name}
  description={description}
  keywords={tags}
  canonical={`/projects/${project.slug}/`}
  ogImage={thumbnail}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": name,
    "description": description,
    "url": url,
    "codeRepository": url,
    "programmingLanguage": language,
    "license": `https://spdx.org/licenses/${license}`,
    "applicationCategory": categories.join(", "),
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  })} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="mb-6 text-sm font-body text-gray-500">
      <a href="/" class="hover:text-charcoal transition-colors no-underline">الرئيسية</a>
      <span class="mx-2">/</span>
      <a href="/projects/" class="hover:text-charcoal transition-colors no-underline text-gray-500">المشاريع</a>
      <span class="mx-2">/</span>
      {categories.map((cat, i) => (
        <>
          <a
            href={`/projects/category/${cat}/`}
            class="hover:text-charcoal transition-colors no-underline text-gray-500"
          >
            {cat}
          </a>
          {i < categories.length - 1 && <span class="mx-2">,</span>}
        </>
      ))}
    </nav>

    {
      thumbnail && (
        <div class="bg-gray-100 rounded-xl overflow-hidden mb-8">
          <img src={thumbnail} alt={name} width="720" height="405" class="w-full h-auto" />
        </div>
      )
    }

    <div class="flex flex-wrap items-center gap-3 text-sm font-body text-gray-500 mb-4">
      {categories.map((cat) => (
        <a
          href={`/projects/category/${cat}/`}
          class="inline-block px-3 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full hover:bg-gray-700 transition-colors no-underline"
        >
          {cat}
        </a>
      ))}
      <span>{language}</span>
      <span>•</span>
      <span>{license}</span>
    </div>

    <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-extrabold text-charcoal mb-6 leading-snug">
      {name}
    </h1>

    <p class="font-body text-lg text-gray-600 leading-relaxed mb-8">
      {description}
    </p>

    <div class="flex gap-3 mb-8">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-charcoal text-white rounded-lg hover:bg-gray-800 transition-colors no-underline"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        GitHub
      </a>
      <a
        href={website}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 font-body text-sm font-medium bg-gray-100 text-charcoal rounded-lg hover:bg-gray-200 transition-colors no-underline"
      >
        الموقع الرسمي
      </a>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-8">
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">التصنيف</span>
        <span class="font-heading text-sm font-bold text-charcoal">{categories.join(", ")}</span>
      </div>
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">اللغة</span>
        <span class="font-heading text-sm font-bold text-charcoal">{language}</span>
      </div>
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">النجوم</span>
        <span class="font-heading text-sm font-bold text-charcoal">{stars}</span>
      </div>
      <div class="bg-gray-50 rounded-xl p-4">
        <span class="block font-body text-xs text-gray-500 mb-1">الرخصة</span>
        <span class="font-heading text-sm font-bold text-charcoal">{license}</span>
      </div>
    </div>

    {features && features.length > 0 && (
      <div class="mb-8">
        <h2 class="font-heading text-xl font-bold text-charcoal mb-4">المميزات</h2>
        <ul class="space-y-2">
          {features.map((feature) => (
            <li class="flex items-center gap-2 font-body text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    )}

    {useCases && useCases.length > 0 && (
      <div class="mb-8">
        <h2 class="font-heading text-xl font-bold text-charcoal mb-4">حالات الاستخدام</h2>
        <div class="flex flex-wrap gap-2">
          {useCases.map((useCase) => (
            <span class="px-3 py-1.5 text-sm font-body text-gray-600 bg-gray-100 rounded-full">
              {useCase}
            </span>
          ))}
        </div>
      </div>
    )}

    {relatedProjects.length > 0 && (
      <div class="mt-10 pt-6 border-t border-gray-100">
        <h2 class="font-heading text-lg font-bold text-charcoal mb-4">مشاريع مشابهة</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedProjects.map((rp) => (
            <a
              href={`/projects/${rp.slug}/`}
              class="block p-4 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors no-underline"
            >
              <h3 class="font-heading text-sm font-bold text-charcoal mb-1">{rp.name}</h3>
              <p class="font-body text-xs text-gray-500 line-clamp-2">{rp.description}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="mt-8 pt-6 border-t border-gray-100">
      <p class="font-body text-sm font-medium text-charcoal mb-3">شارك المشروع</p>
      <div class="flex gap-3">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(name)}&url=${encodeURIComponent(projectUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
          aria-label="شارك على X"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a
          href={`https://reddit.com/submit?url=${encodeURIComponent(projectUrl)}&title=${encodeURIComponent(name)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
          aria-label="شارك على Reddit"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
        </a>
        <a
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(projectUrl)}&title=${encodeURIComponent(name)}&summary=${encodeURIComponent(description)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
          aria-label="شارك على LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a
          href={`https://t.me/share/url?url=${encodeURIComponent(projectUrl)}&text=${encodeURIComponent(name)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
          aria-label="شارك على تلغرام"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.492-1.302.48-.428-.013-1.252-.242-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        </a>
      </div>
    </div>

    <div class="mt-8">
      <a
        href="/projects/"
        class="inline-flex items-center gap-2 font-body text-sm font-medium text-charcoal hover:text-gray-600 transition-colors no-underline"
      >
        &larr; العودة إلى المشاريع
      </a>
    </div>
  </article>
</BaseLayout>
