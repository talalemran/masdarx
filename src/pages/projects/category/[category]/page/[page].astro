---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.astro";
import { projects } from "@/data/projects";

export async function getStaticPaths() {
  const categories = [...new Set(projects.flatMap((p) => Array.isArray(p.category) ? p.category : [p.category]))];
  const pageSize = 6;

  const paths = [];

  for (const category of categories) {
    const filteredProjects = projects.filter((p) => {
      const cats = Array.isArray(p.category) ? p.category : [p.category];
      return cats.includes(category);
    }).reverse();
    const totalPages = Math.ceil(filteredProjects.length / pageSize);

    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { category, page: String(page) },
        props: { category, projects, page, totalPages },
      });
    }
  }

  return paths;
}

export interface Props {
  category: string;
  projects: typeof projects;
  page: number;
  totalPages: number;
}

const { category, projects: allProjects, page, totalPages } = Astro.props;
const pageSize = 6;
const filteredProjects = allProjects.filter((p) => {
  const cats = Array.isArray(p.category) ? p.category : [p.category];
  return cats.includes(category);
}).reverse();
const pageProjects = filteredProjects.slice((page - 1) * pageSize, page * pageSize);

const basePath = `/projects/category/${category}/page`;
---

<BaseLayout
  title={`مشاريع ${category} - الصفحة ${page}`}
  description={`مشاريع ${category} على مصدر إكس - الصفحة ${page}`}
  keywords={[category, "مشاريع مفتوحة المصدر", "مفتوح المصدر"]}
  canonical={`/projects/category/${category}/page/${page}/`}
  ogType="website"
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="mb-6 text-sm font-body text-gray-500">
      <a href="/" class="hover:text-charcoal transition-colors no-underline">الرئيسية</a>
      <span class="mx-2">/</span>
      <a href="/projects/" class="hover:text-charcoal transition-colors no-underline text-gray-500">المشاريع</a>
      <span class="mx-2">/</span>
      <a href={`/projects/category/${category}/`} class="hover:text-charcoal transition-colors no-underline text-gray-500">{category}</a>
      <span class="mx-2">/</span>
      <span class="text-charcoal">الصفحة {page}</span>
    </nav>

    <h1 class="font-heading text-3xl font-extrabold text-charcoal mb-2">
      تصنيف: {category}
    </h1>
    <p class="font-body text-gray-500 mb-8">{filteredProjects.length} مشروع</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {pageProjects.map((project) => (
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
          <a href={`/projects/${project.slug}/`} class="block no-underline">
            {project.thumbnail && (
              <div class="bg-gray-100 overflow-hidden">
                <img
                  src={project.thumbnail}
                  alt={project.name}
                  width="400"
                  height="225"
                  class="w-full h-auto"
                  loading="lazy"
                />
              </div>
            )}
          </a>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <a
                href={`/projects/category/${Array.isArray(project.category) ? project.category[0] : project.category}/`}
                class="px-2 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full hover:bg-gray-700 transition-colors no-underline"
              >
                {Array.isArray(project.category) ? project.category[0] : project.category}
              </a>
              <span class="text-xs font-body text-gray-500">{project.language}</span>
            </div>
            <a href={`/projects/${project.slug}/`} class="block no-underline">
              <h3 class="font-heading text-lg font-bold text-charcoal mb-2 hover:text-gray-700 transition-colors">
                {project.name}
              </h3>
            </a>
            <p class="font-body text-sm text-gray-600 leading-relaxed mb-3 line-clamp-2">
              {project.description}
            </p>
            <div class="flex items-center gap-3 text-xs font-body text-gray-500">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                {project.stars}
              </span>
              <span>{project.license}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <Pagination currentPage={page} totalPages={totalPages} basePath={basePath} />
  </section>
</BaseLayout>
