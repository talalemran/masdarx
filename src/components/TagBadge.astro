---
export interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
---

{
  href ? (
    <a
      href={href}
      class="inline-block px-3 py-1 text-xs font-medium font-body bg-gray-100 text-charcoal rounded-full hover:bg-gray-200 transition-colors no-underline"
    >
      {tag}
    </a>
  ) : (
    <span class="inline-block px-3 py-1 text-xs font-medium font-body bg-gray-100 text-charcoal rounded-full">
      {tag}
    </span>
  )
}
