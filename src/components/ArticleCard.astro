---
import TagBadge from "./TagBadge.astro";

export interface Props {
  title: string;
  description: string;
  category: string;
  author: string;
  date: string;
  tags: string[];
  slug: string;
  thumbnail?: string;
}

const {
  title,
  description,
  category,
  author,
  date,
  tags,
  slug,
  thumbnail,
} = Astro.props;
---

<article class="relative bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden transition-shadow hover:shadow-md">
  <a href={`/posts/${slug}/`} class="absolute inset-0 z-0 no-underline" aria-label={title}></a>
  {
    thumbnail && (
      <div class="bg-gray-100 overflow-hidden">
        <img
          src={thumbnail}
          alt={title}
          width="400"
          height="225"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
    )
  }

  <div class="p-4 sm:p-5 relative z-10">
    <a
      href={`/category/${category}/`}
      class="inline-block px-3 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full mb-3 hover:bg-gray-700 transition-colors no-underline"
    >
      {category}
    </a>

    <a
      href={`/posts/${slug}/`}
      class="block no-underline group/title"
    >
      <h3 class="font-heading text-lg font-bold text-charcoal mb-2 leading-snug group-hover/title:text-gray-700 transition-colors">
        {title}
      </h3>
    </a>

    <p class="font-body text-sm text-gray-600 leading-relaxed mb-3 line-clamp-2">
      {description}
    </p>

    <div class="flex items-center gap-2 text-xs text-gray-500 font-body mb-3">
      <a
        href={`/author/${author}/`}
        class="hover:text-charcoal transition-colors no-underline text-gray-500"
      >
        {author}
      </a>
      <span>•</span>
      <span>{date}</span>
    </div>

    <div class="flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((tag) => (
        <TagBadge tag={tag} href={`/tags/${tag}/`} />
      ))}
    </div>
  </div>
</article>
