---
import TagBadge from "./TagBadge.astro";

export interface Props {
  post: {
    slug: string;
    title: string;
    description: string;
    category: string | string[];
    author: string;
    date: string;
    tags: string[];
    thumbnail?: string;
    pubDate?: Date;
    keywords?: string[];
  };
  allPosts?: any[];
}

const { post, allPosts = [] } = Astro.props;
const { title, description, author, date, tags, thumbnail, slug } = post;
const categories = Array.isArray(post.category) ? post.category : [post.category];
const category = categories[0];

const postUrl = `https://www.masdarx.com/posts/${slug}/`;
const shareLinks = {
  x: `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`,
  reddit: `https://reddit.com/submit?url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(title)}`,
  linkedin: `https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(title)}&summary=${encodeURIComponent(description)}`,
  telegram: `https://t.me/share/url?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(title)}`,
};

const relatedPosts = allPosts
  .filter((p) => p.slug !== slug)
  .map((p) => {
    const pCategories = Array.isArray(p.category) ? p.category : [p.category];
    const categoryMatch = pCategories.some((c) => categories.includes(c)) ? 2 : 0;
    return {
      ...p,
      score: (p.tags?.filter((t: string) => tags?.includes(t)).length || 0) + categoryMatch,
    };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3);
---

<article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <nav class="mb-6 text-sm font-body text-gray-500">
    <a href="/" class="hover:text-charcoal transition-colors no-underline">الرئيسية</a>
    <span class="mx-2">/</span>
    {categories.map((cat, i) => (
      <>
        <a
          href={`/category/${cat}/`}
          class="hover:text-charcoal transition-colors no-underline text-gray-500"
        >
          {cat}
        </a>
        {i < categories.length - 1 && <span class="mx-2">,</span>}
      </>
    ))}
  </nav>

  {
    thumbnail && (
      <div class="bg-gray-100 rounded-xl overflow-hidden mb-8">
        <img src={thumbnail} alt={title} width="720" height="405" class="w-full h-auto" />
      </div>
    )
  }

  <div class="flex flex-wrap items-center gap-3 text-sm font-body text-gray-500 mb-4">
    {categories.map((cat) => (
      <a
        href={`/category/${cat}/`}
        class="inline-block px-3 py-1 text-xs font-bold font-heading text-white bg-charcoal rounded-full hover:bg-gray-700 transition-colors no-underline"
      >
        {cat}
      </a>
    ))}
    <a
      href={`/author/${author}/`}
      class="hover:text-charcoal transition-colors no-underline text-gray-500"
    >
      {author}
    </a>
    <span>•</span>
    <span>{date}</span>
    <span>•</span>
    <span id="reading-time"></span>
  </div>

  <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-extrabold text-charcoal mb-6 leading-snug">
    {title}
  </h1>

  <div class="post-content font-body text-base text-charcoal leading-relaxed">
    <slot />
  </div>

  {relatedPosts.length > 0 && (
    <div class="mt-10 pt-6 border-t border-gray-100">
      <h2 class="font-heading text-lg font-bold text-charcoal mb-4">مقالات ذات صلة</h2>
      <ul class="space-y-2">
        {relatedPosts.map((rp) => (
          <li>
            <a
              href={`/posts/${rp.slug}/`}
              class="font-body text-charcoal hover:text-gray-600 transition-colors no-underline"
            >
              {rp.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <div class="flex flex-wrap gap-2 mt-10 pt-6 border-t border-gray-100">
    {tags?.map((tag) => (
      <TagBadge tag={tag} href={`/tags/${tag}/`} />
    ))}
  </div>

  <div class="mt-8 pt-6 border-t border-gray-100">
    <p class="font-body text-sm font-medium text-charcoal mb-3">شارك المقال</p>
    <div class="flex gap-3">
      <a
        href={shareLinks.x}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
        aria-label="شارك على X"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a
        href={shareLinks.reddit}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
        aria-label="شارك على Reddit"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
      </a>
      <a
        href={shareLinks.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
        aria-label="شارك على LinkedIn"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a
        href={shareLinks.telegram}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-gray-100 text-gray-600 hover:bg-charcoal hover:text-white transition-colors no-underline"
        aria-label="شارك على تلغرام"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.492-1.302.48-.428-.013-1.252-.242-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </a>
    </div>
  </div>

  <a href="https://buymeacoffee.com/masdarx" target="_blank" rel="noopener noreferrer" class="block mt-8 p-6 bg-gradient-to-l from-charcoal to-gray-800 rounded-xl text-center no-underline group">
    <p class="font-heading text-xl font-bold text-white mb-2 group-hover:scale-105 transition-transform">أعجبك المقال؟</p>
    <p class="font-body text-base text-white">ادعم مصدر إكس لنستمر في تقديم محتوى عربي مميز</p>
  </a>

  <div class="mt-8">
    <a
      href="/"
      class="inline-flex items-center gap-2 font-body text-sm font-medium text-charcoal hover:text-gray-600 transition-colors no-underline"
    >
      &larr; العودة إلى الرئيسية
    </a>
  </div>
</article>

<script>
  function calculateReadingTime() {
    const article = document.querySelector('.post-content');
    const readingTimeEl = document.getElementById('reading-time');
    if (!article || !readingTimeEl) return;

    const text = article.textContent || '';
    const wordCount = text.trim().split(/\s+/).length;
    const wordsPerMinute = 200;
    const minutes = Math.ceil(wordCount / wordsPerMinute);

    readingTimeEl.textContent = `${minutes} دقيقة قراءة`;
  }

  calculateReadingTime();
</script>
