---
import MetaTags from "@/components/seo/MetaTags.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

export interface Props {
  title: string;
  description: string;
  keywords?: string[];
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  keywords = [],
  canonical,
  ogImage,
  ogType,
  noIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="مصدر إكس" href="/rss.xml" />
    <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />
    <link rel="me" href="https://mastodon.social/@masdarx" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="69a36a5f-9ab7-4623-948e-243261cd98a3"></script>
    <MetaTags
      {title}
      {description}
      {keywords}
      {canonical}
      {ogImage}
      {ogType}
      {noIndex}
    />
    <style>
      html, body {
        overflow-x: hidden !important;
      }
      .post-content p,
      .post-content h2,
      .post-content h3,
      .post-content ul,
      .post-content ol {
        margin: 0 0 1.5rem 0 !important;
      }
      .post-content > :last-child {
        margin-bottom: 0 !important;
      }
      .post-content ul,
      .post-content ol {
        padding-right: 1.5rem;
      }
      .post-content li {
        margin-bottom: 0.5rem;
      }
      .post-content a {
        color: #1A1A1A;
        text-decoration: underline;
        font-weight: 500;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <button
      id="back-to-top"
      class="fixed bottom-6 left-6 z-50 w-10 h-10 bg-charcoal text-white rounded-full shadow-lg flex items-center justify-center opacity-0 invisible transition-all duration-300 hover:bg-gray-700 cursor-pointer"
      aria-label="العودة للأعلى"
      type="button"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      (function () {
        var btn = document.getElementById("back-to-top");
        if (!btn) return;

        window.addEventListener("scroll", function () {
          if (window.scrollY > 400) {
            btn.classList.remove("opacity-0", "invisible");
            btn.classList.add("opacity-100", "visible");
          } else {
            btn.classList.add("opacity-0", "invisible");
            btn.classList.remove("opacity-100", "visible");
          }
        });

        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      })();
    </script>
  </body>
</html>
